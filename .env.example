# ── MongoDB ──────────────────────────────────────────
# Development: local Docker instance
MONGO_URI=mongodb://localhost:27017/habit_tracker
# Production (MongoDB Atlas SRV string):
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/habit_tracker?retryWrites=true&w=majority

# ── JWT — Access token (short-lived) ────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRES_IN=15m

# ── JWT — Refresh token (long-lived, separate secret)
# Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-string
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────
API_PORT=4000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────
# Development: Vite dev server
CORS_ORIGIN=http://localhost:5173
# Production: your Vercel URL (no trailing slash)
# CORS_ORIGIN=https://habit-tracker.vercel.app

# ── Frontend (Vite) ──────────────────────────────────
VITE_API_URL=http://localhost:4000/api
# Production: your Render service URL
# VITE_API_URL=https://habit-tracker-api.onrender.com/api
